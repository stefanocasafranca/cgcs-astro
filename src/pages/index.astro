---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import TeamCarousel from '../components/TeamCarousel.astro';
import InitiativeCard from '../components/InitiativeCard.astro';
import EventCard from '../components/EventCard.astro';
import ImpactCounter from '../components/ImpactCounter.astro';
import SimulationsModal from '../components/SimulationsModal.astro';

const initiatives = [
  {
    title: 'Public Service',
    description: 'Engage in acts of public service that contribute to addressing pressing real-world problems alongside your peers and members of the community and local government while developing professional skills.',
    href: '/initiatives/public-service',
    icon: 'public-service' as const,
  },
  {
    title: 'Civic Leadership',
    description: 'Participate in events designed to teach or enhance leadership skills in realistic environments applicable to professional life and democratic citizenship.',
    href: '/initiatives/civic-leadership',
    icon: 'civic-leadership' as const,
  },
  {
    title: 'Citizenship & Tech',
    description: 'Harness technology for the common good. Engage in collaborative problem-solving—no technical background required—to build the resilience and practical skills essential for active 21st-century citizenship.',
    href: '/initiatives/citizenship-tech',
    icon: 'citizenship-tech' as const,
  },
];

const simulationsData = {
  id: 'harmony-simulations-modal',
  title: 'Simulations',
  description: 'The CGCS develops simulations to train specific leadership skills and attributes and based on the specified skills and attributes develops learning and simulation objectives.',
  bullets: [
    'The CGCS is eager to work with Students, Staff, and Faculty to run existing simulations or to develop and run new simulations tailored to specific educational desires and needs. If interested, click the "Propose a Simulation" banner.',
    'Each simulation is based on a scenario with roles developed for students to "play" in order to develop and practice leadership skills in a manner designed to provide specific, detailed feedback.',
    'The CGCS offers Skill Building Workshops lasting two hours in length in advance of simulations to teach specific skill sets participants can apply during the simulation. Participation is optional and open regardless of whether scheduled to participate in a simulation or not.',
    'The CGCS is in the process of developing a Civic Leadership Badge and eventually a micro-credential. Stay tuned for details.',
  ],
  stats: [
    {
      icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>',
      value: '86',
      label: 'Participants who completed simulations',
    },
    {
      icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/></svg>',
      value: '344',
      label: 'Total leadership training hours delivered',
    },
  ],
  simulations: [
    {
      id: 'virescenia',
      name: 'Virescenia',
      focus: 'Strategic Communication',
      iconColor: '#f59e0b',
      catalogueDescription: 'An Austin based bio-technology company has inadvertently created a novel disease. The Mayor has called a public meeting to address concerns and solicit citizen cooperation. Assume a role on the Mayor\'s team to prevent panic and obtain support or assume the role of a member of the public trying to shape city policy, influence your fellow residents, or obtain specific information.',
      scenarioDescription: 'Local biotech company GeneSys created Luxaflora – a genetically modified house plant. It appears that Luxaflora has led to a new disease. Take on the role of either a government official or a member of the public and attend a public meeting called by the mayor to discuss the crisis.',
      meta: { age: '14+', players: '20+', duration: '4+ Hours' },
      image: '/images/simulation-virescenia.jpg',
      learningObjectives: {
        image: '/images/virescenia-learning-objectives.jpg',
        objectives: [
          '"Read a room" crafting and delivering messages to obtain information you need',
          'Shape the behavior of either the government or the public',
          'Obtain critical information or influence decision-making in high-pressure settings',
        ],
      },
    },
    {
      id: 'genesys',
      name: 'GeneSys',
      focus: 'Ethical Decision-Making in Crisis',
      iconColor: '#00A651',
      catalogueDescription: 'The Austin based bio-tech company has called a meeting of its board to set priorities in dealing with the crisis (Virescenia). Attend the meeting as a member of the board and employ ethical decision-making frameworks as you attempt to convince the board to adopt your specific priorities.',
      scenarioDescription: 'The Austin based bio-tech company has called a meeting of its board to set priorities regarding the crisis. Attend as a board member (Chief Science Officer, Legal Counsel, etc.) and employ ethical decision-making frameworks.',
      meta: { age: '14+', players: '5+', duration: '4+ Hours' },
      image: '/images/simulation-genesys.jpg',
      learningObjectives: {
        image: '/images/genesys-learning-objectives.jpg',
        objectives: [
          'Apply ethical theories (utilitarian, deontological) to complex decisions',
          'Negotiate competing interests and stakeholder priorities',
          'Build consensus while balancing personal and institutional ethics',
        ],
      },
    },
    {
      id: 'family-dinner',
      name: 'The Dysfunctional Family Dinner',
      focus: 'Conflict Management & Resolution',
      iconColor: '#00A651',
      catalogueDescription: 'Join "your" dysfunctional family for a holiday dinner and navigate political debates, emotional dynamics, and hidden agendas. Shape and steer the conversation, manage and resolve conflict.',
      scenarioDescription: 'Navigate a family gathering with political debates and hidden agendas to manage conflict constructively during a holiday dinner.',
      meta: { age: '14+', players: '8+', duration: '3+ Hours' },
      image: '/images/simulation-family-dinner.jpg',
      learningObjectives: {
        image: '/images/family-dinner-learning-objectives.jpg',
        objectives: [
          'Strengthen conflict resolution and de-escalation skills',
          'Adapt communication styles to different personalities',
          'Engineer off-ramps from heated discussions while preserving relationships',
        ],
      },
    },
  ],
};

const cgcsEvents = [
  {
    title: 'Harmony Schools Simulation Workshop',
    date: 'March 9',
    time: '8:00 am - 4:00 pm',
    image: '/images/logos/logo-color.png',
    modalId: 'harmony-simulations-modal',
  },
  {
    title: 'Community Conversation on Educating Character',
    date: 'March 10',
    time: '5:00 pm - 9:00 pm',
    image: '/images/logos/logo-color.png',
    href: 'https://infohub.austincc.edu/blog/2026/02/19/youre-invited-community-conversation-on-freedom-virtue-and-community/',
    newTab: true,
  },
  {
    title: 'CTXLF - From Idea to Action',
    date: 'March 11',
    time: '3:30 pm - 7:30 pm',
    image: '/images/ctxlf-logo.webp',
    href: 'https://ctxlearningfestival.com/festival-calendar/business-in-a-box-from-idea-to-action',
    newTab: true,
  },
  {
    title: 'CTXLF - Strategic Communication Workshop',
    date: 'March 12',
    time: '2:30 pm - 4:30 pm',
    image: '/images/ctxlf-logo.webp',
    href: 'https://ctxlearningfestival.com/festival-calendar/strategic-communication-workshop',
    newTab: true,
  },
  {
    title: 'CTXLF - Great Questions Community Seminar',
    date: 'March 12',
    time: '6:00 pm - 9:00 pm',
    image: '/images/ctxlf-logo.webp',
    href: 'https://ctxlearningfestival.com/festival-calendar/great-questions-community-seminar',
    newTab: true,
  },
];

const otherEvents = [];
---

<BaseLayout title="CGCS HomePage">
  <!-- Hero Section -->
  <Hero />

  <!-- Marquee -->
  <Marquee />

  <!-- About Us Section -->
  <section id="aboutUs" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-12">About Us</h2>

      <div class="max-w-4xl mx-auto space-y-6 text-text-light text-lg leading-relaxed text-center">
        <p>
          By, with, and through ACC students, The Center for Government and Civic Service (CGCS) builds and strengthens 21st-century civil society, community, and governance. The CGCS trains and empowers our students to be impactful civic leaders. The Center is a creator, catalyst, and nexus for civic action. CGCS initiatives enable our students to complete their programs by providing them with the skills, sense of belonging, and confidence required to succeed in meaningful careers, and bring positive change to our society.
        </p>
        <p>
          The CGCS also serves as the steward of an exceptional event space available to external organizations at a reasonable cost, as well as to our ACC community free of charge. Click the "Reserve Event Space" tab to fill out a short intake form to begin the reservation process.
        </p>
      </div>
    </div>
  </section>

  <!-- Team Carousel -->
  <TeamCarousel />

  <!-- Initiatives Section -->
  <section id="initiatives" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-12">Initiatives</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {initiatives.map((initiative) => (
          <InitiativeCard
            title={initiative.title}
            description={initiative.description}
            href={initiative.href}
            icon={initiative.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CGCS Events Section -->
  <section id="events" class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-12">CGCS Events</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {cgcsEvents.map((event) => (
          <EventCard
            title={event.title}
            date={event.date}
            time={event.time}
            image={event.image}
            href={event.href}
            newTab={event.newTab}
            modalId={event.modalId}
          />
        ))}
      </div>

    </div>
  </section>

  <SimulationsModal
    id={simulationsData.id}
    title={simulationsData.title}
    description={simulationsData.description}
    bullets={simulationsData.bullets}
    stats={simulationsData.stats}
    simulations={simulationsData.simulations}
  />

  <script>
    document.querySelectorAll('[data-modal]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const modalId = (btn as HTMLElement).dataset.modal;
        const modal = document.getElementById(modalId!) as HTMLDialogElement;
        modal?.showModal();
      });
    });
  </script>

  <!-- Badges Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-4xl font-bold text-text-dark mb-12">Badges</h2>

      <!-- Technology & Civic Leadership Badge - Main Badge -->
      <div class="main-badge-section">
        <div class="main-badge-image">
          <a href="https://app.suitable.co/institution/887/activities/470291" target="_blank" rel="noopener noreferrer">
            <img
              src="/images/technology-civic-leadership-badge.png"
              alt="ACC Technology & Civic Leadership Badge"
              width="280"
              height="280"
              class="w-full max-w-[280px] object-contain hover:scale-105 transition-transform"
            />
          </a>
        </div>
        <div class="main-badge-content">
          <h3 class="main-badge-title">TECHNOLOGY & CIVIC LEADERSHIP BADGE</h3>
          <p class="main-badge-text">
            Earn a Technology & Civic Leadership badge by attending three qualifying events and completing a short reflection in <a href="https://app.suitable.co/login" target="_blank" rel="noopener noreferrer" class="text-link">Suitable</a>. Be sure to check in with the CGCS! We are working to create more badging opportunities.
          </p>
        </div>
      </div>

      <!-- Mini Milestone Badges -->
      <div class="milestone-section">
        <p class="milestone-label">Qualifying Event Badges</p>
        <p class="milestone-hint">Attend any 3 events from the options below to earn the Technology & Civic Leadership Badge</p>
        <div class="milestone-badges">
          <a href="https://austin-ai.org/events/" target="_blank" rel="noopener noreferrer" class="milestone-card group">
            <img src="/images/2025/12/aaiaBrandedBadge.png" alt="Austin AI Alliance" loading="lazy" decoding="async" width="180" height="180" class="w-full aspect-square object-contain p-3 group-hover:scale-105 transition-transform duration-300" />
          </a>
          <a href="https://www.austinforum.org/events" target="_blank" rel="noopener noreferrer" class="milestone-card group">
            <img src="/images/2025/12/aftsBrandedBadge.png" alt="Austin on Technology & Society" loading="lazy" decoding="async" width="180" height="180" class="w-full aspect-square object-contain p-3 group-hover:scale-105 transition-transform duration-300" />
          </a>
          <a href="https://www.meetup.com/austin-langchain-ai-group/" target="_blank" rel="noopener noreferrer" class="milestone-card group">
            <img src="/images/2025/12/langchainBrandedBadge.png" alt="Austin LangChain AIMUG" loading="lazy" decoding="async" width="180" height="180" class="w-full aspect-square object-contain p-3 group-hover:scale-105 transition-transform duration-300" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Other Events Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-12">Other Events of Interest</h2>

      <div class="max-w-md mx-auto">
        {otherEvents.map((event) => (
          <EventCard
            title={event.title}
            date={event.date}
            image={event.image}
            href={event.href}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Impact Counters -->
  <ImpactCounter />

  <!-- State of Civil Society Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-12">The State of Civil Society</h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8">
          <blockquote class="text-xl text-text-light italic border-l-4 border-primary pl-6">
            <p>"Liberty cannot be preserved without a general knowledge among the people"</p>
            <footer class="mt-4 text-text-dark font-semibold">~ John Adams</footer>
          </blockquote>

          <blockquote class="text-xl text-text-light italic border-l-4 border-primary pl-6">
            <p>"The life of a nation is secure only while the nation is honest, truthful, and virtuous..."</p>
            <footer class="mt-4 text-text-dark font-semibold">~ Frederick Douglass</footer>
          </blockquote>
        </div>

        <div class="relative">
          <div class="aspect-[4/3] overflow-hidden rounded-2xl shadow-xl">
            <img
              src="/images/civil-society-building.png"
              alt="Civil Society"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Decorative elements -->
          <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-yellow rounded-full -z-10"></div>
          <div class="absolute -top-4 -left-4 w-16 h-16 bg-accent-orange rounded-full -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .main-badge-section {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
      margin-bottom: 4rem;
      text-align: center;
    }

    @media (min-width: 768px) {
      .main-badge-section {
        flex-direction: row;
        align-items: flex-start;
        text-align: left;
      }
    }

    .main-badge-image {
      flex-shrink: 0;
    }

    .main-badge-content {
      max-width: 600px;
    }

    .main-badge-title {
      font-size: 1.75rem;
      font-weight: 700;
      color: #1e3a5f;
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.025em;
    }

    .main-badge-text {
      color: #1e3a5f;
      font-size: 1.125rem;
      line-height: 1.8;
    }

    .milestone-section {
      border-top: 1px solid #e5e7eb;
      padding-top: 2.5rem;
    }

    .milestone-label {
      font-size: 0.875rem;
      font-weight: 600;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
    }

    .milestone-hint {
      color: #6b7280;
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
    }

    .milestone-badges {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      max-width: 540px;
    }

    @media (max-width: 640px) {
      .milestone-badges {
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
      }
    }

    .milestone-card {
      display: block;
      border: 2px solid #1e3a5f;
      border-radius: 0.75rem;
      background: white;
      transition: all 0.3s ease;
    }

    .milestone-card:hover {
      box-shadow: 0 4px 16px rgba(30, 58, 95, 0.15);
    }

    .text-link {
      color: #00A651;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .text-link:hover {
      color: #1e3a5f;
    }
  </style>
</BaseLayout>
