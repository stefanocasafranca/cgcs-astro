---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Book an Event Space">
  <!-- Header -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-accent-orange font-medium mb-4">Leadership – Education – Service</p>
        <h1 class="text-4xl md:text-5xl font-bold text-text-dark mb-6">Want to use our Event Space?</h1>
        <p class="text-lg text-text-light">
          <strong class="text-text-dark">We're here to connect, collaborate, and support.</strong> The Center for Government and Civic Service (CGCS) welcomes inquiries from students, staff, faculty, partners, and community members. Please provide us with initial event details.
        </p>
      </div>
    </div>
  </section>

  <!-- Calendar Availability Section -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-text-dark text-center mb-3">Check Our Availability</h2>
      <p class="text-text-light text-center mb-6">
        Review our calendar before booking. Colored blocks indicate the space is already reserved.
      </p>
      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-200">
        <iframe
          src="https://calendar.google.com/calendar/embed?src=c_afaea34169f9e252afd545081e551f140dcefa691c2a8fcd8c6f9cec1c0c4f9d%40group.calendar.google.com&ctz=America%2FChicago&mode=WEEK"
          style="border: 0"
          width="100%"
          height="500"
          frameborder="0"
          scrolling="no"
          loading="lazy"
          class="w-full"
          title="CGCS Events Calendar"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Booking Form Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-accent-teal/10 rounded-3xl p-8 md:p-12">
        <form class="space-y-6" id="booking-form">
          <!-- Date & Time Selection - FIRST -->
          <div class="bg-white/50 rounded-xl p-5 border border-accent-teal/20">
            <p class="text-sm text-text-light mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-teal flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Please check the calendar above to ensure your preferred time is available.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-text-dark mb-2">
                  Event Date *
                </label>
                <input
                  type="date"
                  name="eventDate"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent bg-white"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-text-dark mb-2">
                  Event Start Time *
                </label>
                <input
                  type="time"
                  name="startTime"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent bg-white"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-text-dark mb-2">
                  Event End Time *
                </label>
                <input
                  type="time"
                  name="endTime"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent bg-white"
                />
              </div>
            </div>
          </div>

          <!-- Organization Name -->
          <div>
            <input
              type="text"
              name="organizationName"
              placeholder="Organization Name *"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
            />
          </div>

          <!-- Primary Point of Contact -->
          <div>
            <input
              type="text"
              name="contactName"
              placeholder="Primary Point of Contact (full name) *"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
            />
          </div>

          <!-- Email and Phone -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <input
                type="email"
                name="email"
                placeholder="POC Email *"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
              />
            </div>
            <div class="flex items-center gap-2">
              <span class="text-gray-500">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </span>
              <input
                type="tel"
                name="phone"
                placeholder="Phone # *"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
              />
            </div>
          </div>

          <!-- Event Title and Attendees -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <input
                type="text"
                name="eventTitle"
                placeholder="Event Title"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
              />
            </div>
            <div>
              <input
                type="number"
                name="attendees"
                min="1"
                placeholder="Estimated Attendees *"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
              />
            </div>
          </div>

          <!-- Audio/Visual and Catering -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-text-dark mb-3">
                Audio/Visual Support Required *
              </label>
              <div class="flex gap-6">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="radio"
                    name="avSupport"
                    value="yes"
                    required
                    class="w-4 h-4 text-primary focus:ring-primary"
                  />
                  <span class="text-text-dark">Yes</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="radio"
                    name="avSupport"
                    value="no"
                    class="w-4 h-4 text-primary focus:ring-primary"
                  />
                  <span class="text-text-dark">No</span>
                </label>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-text-dark mb-3">
                Catering Required *
              </label>
              <div class="flex gap-6">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="radio"
                    name="catering"
                    value="yes"
                    required
                    class="w-4 h-4 text-primary focus:ring-primary"
                  />
                  <span class="text-text-dark">Yes</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="radio"
                    name="catering"
                    value="no"
                    class="w-4 h-4 text-primary focus:ring-primary"
                  />
                  <span class="text-text-dark">No</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Additional Details -->
          <div>
            <textarea
              name="additionalDetails"
              placeholder="Provide Additional Details"
              rows="4"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            class="btn-primary w-full justify-center"
          >
            Get in Touch
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>

          <!-- Note -->
          <p class="text-sm text-text-light text-center italic">
            Please allow 1–4 business days for a response. We appreciate your interest and look forward to working together.
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="h-96 bg-gray-200">
    <iframe
      src="https://www.google.com/maps?q=1218+West+Ave,+Austin,+TX+78701&output=embed"
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="CGCS Location Map"
    ></iframe>
  </section>
</BaseLayout>

<script>
  const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY;

  const form = document.getElementById('booking-form') as HTMLFormElement | null;
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!WEB3FORMS_KEY) {
      console.error('PUBLIC_WEB3FORMS_KEY is not set');
      alert('Form is not configured. Please contact us directly at admin@cgcsacc.org');
      return;
    }

    const data = new FormData(form);

    const avSupport = data.get('avSupport') as string;
    const catering = data.get('catering') as string;
    const setupParts: string[] = [];
    if (avSupport === 'yes') setupParts.push('A/V support required');
    if (catering === 'yes') setupParts.push('catering required');

    const requesterName = (data.get('contactName') as string).trim();

    const payload = {
      access_key: WEB3FORMS_KEY,
      subject: `Event Space Request — ${(data.get('organizationName') as string).trim() || requesterName}`,
      from_name: requesterName,
      email: (data.get('email') as string).trim().toLowerCase(),
      // Human-readable fields that appear in the email body
      'Organization': (data.get('organizationName') as string).trim() || '—',
      'Contact Name': requesterName,
      'Phone': (data.get('phone') as string).trim(),
      'Event Title': (data.get('eventTitle') as string || '').trim() || '—',
      'Event Date': data.get('eventDate') as string,
      'Start Time': data.get('startTime') as string,
      'End Time': data.get('endTime') as string,
      'Estimated Attendees': data.get('attendees') as string || '—',
      'A/V Support': avSupport === 'yes' ? 'Yes' : 'No',
      'Catering': catering === 'yes' ? 'Yes' : 'No',
      'Setup Requirements': setupParts.length > 0 ? setupParts.join(', ') : 'None',
      'Additional Details': (data.get('additionalDetails') as string || '').trim() || '—',
    };

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting…';
    }

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const result = await res.json();
      if (!res.ok || !result.success) throw new Error(result.message || `HTTP ${res.status}`);

      // Replace form with confirmation message
      const section = form.closest('section');
      if (section) {
        section.innerHTML = `
          <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-16">
            <div class="bg-accent-teal/10 rounded-3xl p-10 md:p-16">
              <svg class="w-16 h-16 text-accent-teal mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <h2 class="text-3xl font-bold text-text-dark mb-4">Request Received!</h2>
              <p class="text-text-light text-lg">
                Thanks, <strong class="text-text-dark">${requesterName}</strong>. We've received your request and will be in touch within 1–4 business days.
              </p>
            </div>
          </div>`;
      }
    } catch (err) {
      console.error('Submission error:', err);
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Get in Touch';
      }
      alert('Something went wrong submitting your request. Please try again or email us directly at admin@cgcsacc.org');
    }
  });
</script>
