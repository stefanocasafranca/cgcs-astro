---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Book an Event Space">
  <!-- Header -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-accent-orange font-medium mb-4">Leadership – Education – Service</p>
        <h1 class="text-4xl md:text-5xl font-bold text-text-dark mb-6">Want to use our Event Space?</h1>
        <p class="text-lg text-text-light">
          <strong class="text-text-dark">We're here to connect, collaborate, and support.</strong> The Center for Government and Civic Service (CGCS) welcomes inquiries from students, staff, faculty, partners, and community members. Please provide us with initial event details.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- GOOGLE CALENDAR SECTION - TEMPORARILY HIDDEN               -->
  <!-- To restore: remove the outer comment tags wrapping the     -->
  <!-- <section> block below (the ones that say HIDDEN START/END) -->
  <!-- ============================================================ -->

  <!-- GOOGLE CALENDAR HIDDEN START
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-text-dark text-center mb-3">Check Our Availability</h2>
      <p class="text-text-light text-center mb-6">
        Review our calendar before booking. Colored blocks indicate the space is already reserved.
      </p>
      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-200">
        <iframe
          src="https://calendar.google.com/calendar/embed?src=c_afaea34169f9e252afd545081e551f140dcefa691c2a8fcd8c6f9cec1c0c4f9d%40group.calendar.google.com&ctz=America%2FChicago&mode=WEEK"
          style="border: 0"
          width="100%"
          height="500"
          frameborder="0"
          scrolling="no"
          loading="lazy"
          class="w-full"
          title="CGCS Events Calendar"
        ></iframe>
      </div>
    </div>
  </section>
  GOOGLE CALENDAR HIDDEN END -->

  <!-- Booking Form Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 md:p-12">

        <h2 class="text-2xl md:text-3xl font-bold text-text-dark mb-3">Austin Community College Event Request Form</h2>
        <p class="text-text-light mb-8">
          Reservations are managed through Austin Community College's official request system. The form covers all event details and typically takes <strong class="text-text-dark">up to 10-15 minutes</strong> to complete. Have the following ready before you begin:
        </p>

        <ul class="space-y-3 mb-10">
          {[
            'Your name, email, and phone number',
            'Preferred event date(s) and times',
            'Estimated number of attendees',
            'A/V, catering, and room setup needs',
            'Your organization or department name',
          ].map(item => (
            <li class="flex items-start gap-3 text-text-light">
              <svg class="w-5 h-5 text-accent-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </li>
          ))}
        </ul>

        <a
          href="https://app.smartsheet.com/b/form/cd2f5559c5b6458fbfe61490f4a90f93"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary inline-flex items-center gap-2 text-base"
        >
          Open Event Request Form
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>

        <p class="text-sm text-text-light mt-6 italic">
          Event requests are not guaranteed until full payment is received. Please allow 1–4 business days for a response.
        </p>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="h-96 bg-gray-200">
    <iframe
      src="https://www.google.com/maps?q=1218+West+Ave,+Austin,+TX+78701&output=embed"
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="CGCS Location Map"
    ></iframe>
  </section>
</BaseLayout>
