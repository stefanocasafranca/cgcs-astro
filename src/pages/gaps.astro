---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="GAPS Internship"
  description="Generative AI for Public Service (GAPS) — Build Real AI. Serve Real People. Fall 2026 internship at Austin Community College."
>
  <!-- Breadcrumbs -->
  <nav class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-text-light">
        <li><a href="/" class="hover:text-primary">Home</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/initiatives/public-service" class="hover:text-primary">Public Service Initiative</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-text-dark font-medium">GAPS Internship</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative bg-[#1e3a5f] text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#1e3a5f] via-[#1e3a5f] to-primary/30"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 text-center">
      <p class="text-primary font-semibold tracking-wide uppercase mb-4">Fall 2026 Internship</p>
      <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-6">
        Build Real AI.<br />Serve Real People.
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 mb-4">
        Generative AI for Public Service (GAPS)
      </p>
      <p class="text-lg text-gray-400 mb-10">
        Any major. Any background. No experience needed.
      </p>

      <p class="text-sm text-gray-400 mb-10">In partnership with <a href="https://thepublicservicedesk.org" target="_blank" rel="noopener noreferrer" class="underline hover:text-white">The Public Service Desk</a></p>

      <a
        href="https://austincc.joinhandshake.com/jobs/10984374"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-lg px-8 py-4"
      >
        Apply on Handshake
      </a>
    </div>
  </section>

  <!-- What Is It -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="section-heading mb-8">What Is GAPS?</h2>
      <p class="text-lg text-text-light leading-relaxed mb-8">
        One semester. One client. Design, build, and deploy an AI tool for a public institution.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
        <div class="bg-gray-50 rounded-xl p-6 flex flex-col items-center justify-center min-h-[140px]">
          <p class="text-sm text-text-light uppercase tracking-wide mb-2">Type</p>
          <p class="text-lg font-bold text-text-dark text-center">Non-paid Internship</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 flex flex-col items-center justify-center min-h-[140px]">
          <p class="text-sm text-text-light uppercase tracking-wide mb-2">Term</p>
          <p class="text-lg font-bold text-text-dark text-center">Fall 2026</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 flex flex-col items-center justify-center min-h-[140px]">
          <p class="text-sm text-text-light uppercase tracking-wide mb-2">Client</p>
          <p class="text-lg font-bold text-text-dark text-center">ACC Student Life Org</p>
          <p class="text-sm text-text-light text-center">Serve the students</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4 Roles -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-4">4 Roles. Diverse Teams.</h2>
      <p class="text-center text-text-light mb-12">4 open positions per track &mdash; we build diverse teams with complementary skills.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-2xl p-8 shadow-md text-center hover-lift">
          <div class="w-14 h-14 bg-primary/10 text-primary rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text-dark mb-2">Builders</h3>
          <p class="text-text-light text-sm">Develop and deploy the AI tool</p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-md text-center hover-lift">
          <div class="w-14 h-14 bg-accent-orange/10 text-accent-orange rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text-dark mb-2">Designers</h3>
          <p class="text-text-light text-sm">Shape the user experience</p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-md text-center hover-lift">
          <div class="w-14 h-14 bg-accent-teal/10 text-accent-teal rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text-dark mb-2">Researchers</h3>
          <p class="text-text-light text-sm">Investigate needs and validate solutions</p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-md text-center hover-lift">
          <div class="w-14 h-14 bg-yellow/10 text-yellow rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text-dark mb-2">Project Managers</h3>
          <p class="text-text-light text-sm">Coordinate the team and timeline</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who Can Apply -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="section-heading mb-6">Who Can Apply?</h2>
      <p class="text-lg text-text-light leading-relaxed mb-4">
        Any ACC student needing practicum or internship credit.
      </p>
      <p class="text-lg text-text-light leading-relaxed mb-4">
        Any department. Any major. <strong class="text-text-dark">No tech or AI experience needed.</strong>
      </p>
      <p class="text-text-light">
        In partnership with ACC's Office of Experiential Learning.
      </p>
    </div>
  </section>

  <!-- Info Sessions -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-12">Info Sessions</h2>

      <div class="space-y-4">
        <div class="bg-white rounded-xl p-6 shadow-sm flex flex-col sm:flex-row sm:items-center gap-3">
          <span class="font-bold text-primary whitespace-nowrap">Apr 30</span>
          <span class="text-text-dark">Round Rock (Room 8202) &mdash; 12 pm &amp; 4 pm</span>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm flex flex-col sm:flex-row sm:items-center gap-3">
          <span class="font-bold text-primary whitespace-nowrap">May 6</span>
          <span class="text-text-dark">South Austin (Room 1210) &mdash; 12 pm &amp; 4 pm</span>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm flex flex-col sm:flex-row sm:items-center gap-3">
          <span class="font-bold text-primary whitespace-nowrap">May 15</span>
          <span class="text-text-dark">Highland (Room 2421) &mdash; 12 pm &amp; 4 pm</span>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm flex flex-col sm:flex-row sm:items-center gap-3">
          <span class="font-bold text-primary whitespace-nowrap">Jun 3 &amp; Jun 10</span>
          <span class="text-text-dark">Virtual Info Sessions &mdash; contact for link</span>
        </div>
      </div>

      <p class="text-center text-text-light text-sm mt-8">
        Recording links will be posted on <a href="/gaps" class="text-primary font-medium hover:underline">cgcs-acc.org/gaps</a>
      </p>
    </div>
  </section>

  <!-- Contact / CTA Footer -->
  <section class="py-20 bg-[#1e3a5f] text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-6">Ready to Apply?</h2>
      <p class="text-gray-300 mb-2">Questions? Reach out to:</p>
      <div class="relative inline-block">
        <button
          id="copy-email"
          class="text-primary hover:underline text-lg font-medium cursor-pointer"
        >
          stefano.casafrancalaos@austincc.edu
        </button>
        <span id="copy-toast" class="absolute -top-8 left-1/2 -translate-x-1/2 bg-primary text-white text-sm px-3 py-1 rounded-full opacity-0 pointer-events-none transition-opacity duration-300">
          Copied!
        </span>
      </div>

      <div class="flex flex-col items-center gap-4 mt-10">
        <a
          href="https://austincc.joinhandshake.com/jobs/10984374"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-lg px-8 py-4"
        >
          Apply on Handshake
        </a>
      </div>

      <div class="flex justify-center gap-6 mt-10 text-sm text-gray-400">
        <a href="/" class="hover:text-white hover:underline">cgcs-acc.org</a>
        <a href="https://thepublicservicedesk.org" target="_blank" rel="noopener noreferrer" class="hover:text-white hover:underline">thepublicservicedesk.org</a>
      </div>
    </div>
  </section>
  <script>
    document.getElementById('copy-email')?.addEventListener('click', async () => {
      await navigator.clipboard.writeText('stefano.casafrancalaos@austincc.edu');
      const toast = document.getElementById('copy-toast');
      if (toast) {
        toast.style.opacity = '1';
        setTimeout(() => { toast.style.opacity = '0'; }, 1500);
      }
    });
  </script>
</BaseLayout>
