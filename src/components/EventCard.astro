---
interface Props {
  title: string;
  date: string;
  time?: string;
  image: string;
  href?: string;
  newTab?: boolean;
  modalId?: string;
  objectFit?: 'cover' | 'contain';
}

const { title, date, time, image, href = '#', newTab = false, modalId, objectFit = 'cover' } = Astro.props;
const imgClass = `w-full h-full ${objectFit === 'contain' ? 'object-contain' : 'object-cover'} group-hover:scale-105 transition-transform duration-300`;
---

{modalId ? (
  <button data-modal={modalId} class="group block h-full w-full text-left cursor-pointer">
    <div class="bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow h-full flex flex-col">
      <div class="aspect-video overflow-hidden">
        <img
          src={image}
          alt={title}
          loading="lazy"
          decoding="async"
          width="400"
          height="225"
          class={imgClass}
        />
      </div>
      <div class="p-6 flex-1 flex flex-col">
        <h3 class="text-lg font-bold text-text-dark group-hover:text-primary transition-colors flex-1">
          {title}
        </h3>
        <p class="text-primary font-medium mt-2">
          {date}
          {time && <span class="text-text-light"> @ {time}</span>}
        </p>
      </div>
    </div>
  </button>
) : (
  <a href={href} target={newTab ? '_blank' : '_self'} rel={newTab ? 'noopener noreferrer' : undefined} class="group block h-full">
    <div class="bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow h-full flex flex-col">
      <div class="aspect-video overflow-hidden">
        <img
          src={image}
          alt={title}
          loading="lazy"
          decoding="async"
          width="400"
          height="225"
          class={imgClass}
        />
      </div>
      <div class="p-6 flex-1 flex flex-col">
        <h3 class="text-lg font-bold text-text-dark group-hover:text-primary transition-colors flex-1">
          {title}
        </h3>
        <p class="text-primary font-medium mt-2">
          {date}
          {time && <span class="text-text-light"> @ {time}</span>}
        </p>
      </div>
    </div>
  </a>
)}
