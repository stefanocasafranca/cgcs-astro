---
const teamMembers = [
  { name: 'Bryan Port', role: 'Director, CGCS', image: '/images/team/bryan.jpg' },
  { name: 'Marisela Perez', role: 'Strategic Planner in Civic Leadership', image: '/images/team/marisela.jpg' },
  { name: 'Austin Wells', role: 'Strategic Planner for Community Relations and Environmental Affairs', image: '/images/team/austin.jpg' },
  { name: 'Cate Thomason', role: 'Strategic Planner in Public Service', image: 'https://i0.wp.com/cgcsacc.org/wp-content/uploads/2022/10/Cate-ai.png?fit=800%2C750&ssl=1' },
  { name: 'Stefano Casafranca', role: 'Strategic Planner in Citizenship & Tech (UX/AI Technologies)', image: '/images/stefanoFinal2.png' },
  { name: 'Vanessa Trujano', role: 'Strategic Planner and Communicator', image: '/images/team/vanessa.jpg' },
  { name: 'Eimanie Thomas', role: 'Strategic Planner, Business Operations', image: '/images/team/eimanie.jpg' },
  { name: 'Brenden Fogg', role: 'Strategic Planner, Business Operations', image: '/images/team/brenden.jpg' },
];
---

<section class="py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative">
      <!-- Carousel Container -->
      <div id="team-carousel" class="overflow-hidden">
        <div id="team-track" class="flex transition-transform duration-500 ease-in-out">
          {teamMembers.map((member, index) => (
            <div class="flex-shrink-0 w-full sm:w-1/2 md:w-1/3 lg:w-1/4 px-4">
              <div class="bg-white rounded-2xl overflow-hidden shadow-lg">
                <div class="aspect-square overflow-hidden">
                  <img
                    src={member.image}
                    alt={member.name}
                    class={`w-full h-full object-cover ${member.position ? '' : 'object-top'}`}
                    style={member.position ? `object-position: ${member.position}` : ''}
                  />
                </div>
                <div class="p-6 text-center h-[140px] flex flex-col justify-center">
                  <h3 class="text-xl font-bold text-text-dark">{member.name}</h3>
                  <p class="text-text-light mt-1 text-sm leading-tight">{member.role}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation Buttons -->
      <button
        id="prev-btn"
        class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 w-12 h-12 bg-white rounded-full shadow-lg flex items-center justify-center hover:bg-gray-50 transition-colors z-10"
        aria-label="Previous slide"
      >
        <svg class="w-6 h-6 text-text-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        id="next-btn"
        class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 w-12 h-12 bg-white rounded-full shadow-lg flex items-center justify-center hover:bg-gray-50 transition-colors z-10"
        aria-label="Next slide"
      >
        <svg class="w-6 h-6 text-text-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>

    <!-- Dots Navigation with progress bars -->
    <div id="dots-container" class="flex justify-center mt-8 gap-2 items-center"></div>
  </div>
</section>

<style is:global>
  .dot-wrapper {
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    background: #d1d5db;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: width 0.3s ease, background 0.3s ease;
  }
  .dot-wrapper.active {
    width: 40px;
    border-radius: 9999px;
    background: #e5e7eb;
  }
  .dot-wrapper.completed {
    background: var(--color-primary, #16a34a);
  }
  .dot-progress {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background: var(--color-primary, #16a34a);
    border-radius: 9999px;
    transition: none;
  }
  .dot-progress.animating {
    transition: width linear;
  }
</style>

<script>
  const track = document.getElementById('team-track') as HTMLElement;
  const carousel = document.getElementById('team-carousel') as HTMLElement;
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const dotsContainer = document.getElementById('dots-container') as HTMLElement;

  let currentIndex = 0;
  const totalSlides = 8;
  const AUTOPLAY_DURATION = 4000;
  let autoplayTimer: ReturnType<typeof setTimeout> | null = null;
  let isPaused = true; // starts paused until visible
  let isInView = false;
  let isHovered = false;

  // Drag state
  let isDragging = false;
  let startX = 0;
  let currentTranslate = 0;
  let prevTranslate = 0;

  function getVisibleSlides() {
    if (window.innerWidth >= 1024) return 4;
    if (window.innerWidth >= 768) return 3;
    if (window.innerWidth >= 640) return 2;
    return 1;
  }

  function getMaxIndex() {
    return Math.max(0, totalSlides - getVisibleSlides());
  }

  function createDots() {
    const maxIndex = getMaxIndex();
    const numDots = maxIndex + 1;
    dotsContainer.innerHTML = '';

    for (let i = 0; i < numDots; i++) {
      const dot = document.createElement('button');
      dot.className = 'dot-wrapper';
      dot.setAttribute('aria-label', `Go to slide ${i + 1}`);

      const progress = document.createElement('div');
      progress.className = 'dot-progress';
      dot.appendChild(progress);

      dot.addEventListener('click', () => {
        goToSlide(i);
      });
      dotsContainer.appendChild(dot);
    }
  }

  function updateDots() {
    const dots = dotsContainer.querySelectorAll('.dot-wrapper');
    dots.forEach((dot, index) => {
      const progress = dot.querySelector('.dot-progress') as HTMLElement;
      dot.classList.remove('active', 'completed');
      progress.classList.remove('animating');
      progress.style.width = '0%';

      if (index < currentIndex) {
        dot.classList.add('completed');
        progress.style.width = '100%';
      } else if (index === currentIndex) {
        dot.classList.add('active');
      }
    });
  }

  function startProgress() {
    const dots = dotsContainer.querySelectorAll('.dot-wrapper');
    const activeDot = dots[currentIndex];
    if (!activeDot) return;

    const progress = activeDot.querySelector('.dot-progress') as HTMLElement;
    // Reset
    progress.style.width = '0%';
    progress.classList.remove('animating');

    // Force reflow then animate
    void progress.offsetWidth;
    progress.classList.add('animating');
    progress.style.transitionDuration = `${AUTOPLAY_DURATION}ms`;
    progress.style.width = '100%';
  }

  function goToSlide(index: number) {
    currentIndex = index;
    updateCarousel();
    resetAutoplay();
  }

  function updateCarousel() {
    const visibleSlides = getVisibleSlides();
    const slideWidth = 100 / visibleSlides;
    track.style.transform = `translateX(-${currentIndex * slideWidth}%)`;
    updateDots();
  }

  function advanceSlide() {
    const maxIndex = getMaxIndex();
    currentIndex = currentIndex < maxIndex ? currentIndex + 1 : 0;
    updateCarousel();
    startProgress();
    scheduleAutoplay();
  }

  function scheduleAutoplay() {
    if (autoplayTimer) clearTimeout(autoplayTimer);
    if (!isPaused) {
      autoplayTimer = setTimeout(advanceSlide, AUTOPLAY_DURATION);
    }
  }

  function resetAutoplay() {
    if (autoplayTimer) clearTimeout(autoplayTimer);
    updateDots();
    startProgress();
    scheduleAutoplay();
  }

  function updatePauseState() {
    const shouldPause = !isInView || isHovered;
    if (shouldPause && !isPaused) {
      isPaused = true;
      if (autoplayTimer) clearTimeout(autoplayTimer);
      const activeDot = dotsContainer.querySelector('.dot-wrapper.active .dot-progress') as HTMLElement;
      if (activeDot) {
        const computed = getComputedStyle(activeDot);
        activeDot.classList.remove('animating');
        activeDot.style.width = computed.width;
      }
    } else if (!shouldPause && isPaused) {
      isPaused = false;
      resetAutoplay();
    }
  }

  // Pause on hover
  carousel.addEventListener('mouseenter', () => {
    isHovered = true;
    updatePauseState();
  });

  carousel.addEventListener('mouseleave', () => {
    isHovered = false;
    updatePauseState();
  });

  // Start/stop based on visibility
  const section = carousel.closest('section') as HTMLElement;
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      isInView = entry.isIntersecting;
      updatePauseState();
    });
  }, { threshold: 0.2 });
  observer.observe(section);

  // Drag / swipe support
  function getPositionX(e: MouseEvent | TouchEvent) {
    return 'touches' in e ? e.touches[0].clientX : e.clientX;
  }

  function dragStart(e: MouseEvent | TouchEvent) {
    isDragging = true;
    startX = getPositionX(e);
    track.style.transition = 'none';
    isPaused = true;
    if (autoplayTimer) clearTimeout(autoplayTimer);
  }

  function dragMove(e: MouseEvent | TouchEvent) {
    if (!isDragging) return;
    const currentX = getPositionX(e);
    const diff = currentX - startX;
    const visibleSlides = getVisibleSlides();
    const slideWidth = carousel.offsetWidth / visibleSlides;
    const baseTranslate = -(currentIndex * slideWidth);
    track.style.transform = `translateX(${baseTranslate + diff}px)`;
  }

  function dragEnd(e: MouseEvent | TouchEvent) {
    if (!isDragging) return;
    isDragging = false;
    track.style.transition = 'transform 500ms ease-in-out';

    const endX = 'changedTouches' in e ? e.changedTouches[0].clientX : e.clientX;
    const diff = endX - startX;
    const threshold = 80;
    const maxIndex = getMaxIndex();

    if (diff < -threshold && currentIndex < maxIndex) {
      currentIndex++;
    } else if (diff > threshold && currentIndex > 0) {
      currentIndex--;
    }

    updateCarousel();
    updatePauseState();
  }

  // Touch events
  track.addEventListener('touchstart', dragStart, { passive: true });
  track.addEventListener('touchmove', dragMove, { passive: true });
  track.addEventListener('touchend', dragEnd);

  // Mouse drag events
  track.addEventListener('mousedown', dragStart);
  track.addEventListener('mousemove', dragMove);
  track.addEventListener('mouseup', dragEnd);
  track.addEventListener('mouseleave', () => {
    if (isDragging) dragEnd(new MouseEvent('mouseup'));
  });

  // Prevent image dragging
  track.querySelectorAll('img').forEach(img => {
    img.addEventListener('dragstart', (e) => e.preventDefault());
  });

  // Nav buttons
  prevBtn?.addEventListener('click', () => {
    const maxIndex = getMaxIndex();
    currentIndex = currentIndex > 0 ? currentIndex - 1 : maxIndex;
    updateCarousel();
    resetAutoplay();
  });

  nextBtn?.addEventListener('click', () => {
    const maxIndex = getMaxIndex();
    currentIndex = currentIndex < maxIndex ? currentIndex + 1 : 0;
    updateCarousel();
    resetAutoplay();
  });

  window.addEventListener('resize', () => {
    const maxIndex = getMaxIndex();
    if (currentIndex > maxIndex) currentIndex = maxIndex;
    createDots();
    updateCarousel();
    resetAutoplay();
  });

  // Initialize
  createDots();
  updateCarousel();
</script>
